{
  "name": "cambis/silverstan",
  "description": "PHPStan extensions and rules for Silverstripe.",
  "license": "MIT",
  "type": "phpstan-extension",
  "keywords": [
    "silverstripe",
    "phpstan",
    "static analysis"
  ],
  "authors": [
    {
      "name": "Cameron Bryers"
    }
  ],
  "require": {
    "php": "^8.3",
    "phpstan/phpstan": "^2.0",
    "silverstripe/config": "^3.0",
    "silverstripe/framework": "^6.0",
    "symplify/rule-doc-generator-contracts": "^11.2"
  },
  "suggest": {
    "silverstripe/standards": "Verifies annotations inside of Silverstripe classes."
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "autoload": {
    "psr-4": {
      "Cambis\\Silverstan\\": [
        "src/"
      ]
    }
  },
  "config": {
    "allow-plugins": {
      "composer/installers": true,
      "phpstan/extension-installer": true
    },
    "sort-packages": true
  },
  "extra": {
    "phpstan": {
      "includes": [
        "extension.neon"
      ]
    }
  }
}
